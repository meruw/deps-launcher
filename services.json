{
  "uiPort": 9999,
  "openBrowser": true,
  "services": [
    {
      "id": "azurite",
      "group": "infra",
      "name": "Azurite",
      "desc": "Azure Storage Emulator",
      "port": 10000,
      "color": "#F59E0B",
      "cwd": "${ROOT}",
      "cmd": "azurite",
      "args": [],
      "health": { "type": "process" },
      "dependsOn": [],
      "autoRestart": true
    },
    {
      "id": "postgres",
      "group": "infra",
      "name": "PostgreSQL",
      "desc": "Database (Docker container)",
      "port": 5432,
      "color": "#0EA5E9",
      "cwd": "${ROOT}",
      "cmd": "docker",
      "args": ["start", "-a", "${DB_CONTAINER}"],
      "stop": "docker stop ${DB_CONTAINER}",
      "ensure": {
        "label": "Docker Desktop",
        "check": "docker info",
        "start": "${DOCKER_DESKTOP}",
        "stop": "docker desktop stop & wsl --shutdown",
        "timeout": 120000
      },
      "health": { "type": "tcp" },
      "dependsOn": [],
      "autoRestart": false
    },
    {
      "id": "fastbank",
      "group": "backend",
      "name": "FastBank",
      "desc": "Spring Boot Backend",
      "port": 8080,
      "color": "#3B82F6",
      "cwd": "${ROOT}\\FastBank",
      "cmd": "${MVN}",
      "args": ["-pl", "server", "spring-boot:run", "-Dspring-boot.run.profiles=${PROFILE}"],
      "health": { "type": "http", "path": "/actuator/health" },
      "dependsOn": ["azurite", "postgres"],
      "depTimeout": 180000,
      "autoRestart": false
    },
    {
      "id": "featureflags",
      "group": "backend",
      "name": "Feature Flags",
      "desc": "Azure Function :7071",
      "port": 7071,
      "color": "#8B5CF6",
      "cwd": "${ROOT}\\FastBank-Feature_Flags\\FeatureFlag",
      "cmd": "func",
      "args": ["start", "--port", "7071", "--cors", "${CORS_ORIGIN}"],
      "health": { "type": "tcp" },
      "dependsOn": ["azurite"],
      "autoRestart": false
    },
    {
      "id": "company",
      "group": "backend",
      "name": "Company",
      "desc": "Python Azure Function :7072",
      "port": 7072,
      "color": "#10B981",
      "cwd": "${ROOT}\\FastBank-Company",
      "cmd": "powershell",
      "args": ["-NoProfile", "-Command", "& '.\\venv\\Scripts\\Activate.ps1'; func start --port 7072 --cors ${CORS_ORIGIN}"],
      "health": { "type": "tcp" },
      "dependsOn": ["azurite"],
      "autoRestart": false
    },
    {
      "id": "bankrecon",
      "group": "backend",
      "name": "Bank Recon",
      "desc": ".NET Azure Function :7073",
      "port": 7073,
      "color": "#EF4444",
      "cwd": "${ROOT}\\FastBank-BankRecon\\FastBankReconProcess",
      "cmd": "func",
      "args": ["start", "--port", "7073", "--cors", "${CORS_ORIGIN}"],
      "health": { "type": "tcp" },
      "dependsOn": ["azurite"],
      "autoRestart": false
    },
    {
      "id": "webapp",
      "group": "frontend",
      "name": "WebApp",
      "desc": "Angular :4200",
      "port": 4200,
      "color": "#EC4899",
      "cwd": "${ROOT}\\FastBank-WebApp",
      "cmd": "npm",
      "args": ["start"],
      "health": { "type": "tcp" },
      "dependsOn": [],
      "autoRestart": false
    }
  ]
}
